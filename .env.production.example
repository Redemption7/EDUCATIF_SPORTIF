.env.production.example
# Copy this file to .env on your hosting server and fill in the values

APP_NAME="NK EDUCATIF SPORTIF"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-app-url.render.com

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql-server-host
DB_PORT=3306
DB_DATABASE=educatif_sportif
DB_USERNAME=root
DB_PASSWORD=your-password

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=your-username
MAIL_PASSWORD=your-password
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@educatifsportif.com
MAIL_FROM_NAME="${APP_NAME}"

VITE_API_BASE_URL=${APP_URL}
